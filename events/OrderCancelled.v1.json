{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "OrderCancelled.v1",
    "description": "Published when an order is cancelled. Topic: order.events",
    "type": "object",
    "required": [
        "orderId",
        "userEmail",
        "reason",
        "cancelledAt"
    ],
    "properties": {
        "orderId": {
            "type": "string",
            "format": "uuid"
        },
        "userEmail": {
            "type": "string",
            "format": "email"
        },
        "reason": {
            "type": "string"
        },
        "cancelledAt": {
            "type": "string",
            "format": "date-time"
        }
    }
}