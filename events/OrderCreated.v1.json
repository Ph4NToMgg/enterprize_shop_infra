{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "OrderCreated.v1",
    "description": "Published when a new order is confirmed. Topic: order.events",
    "type": "object",
    "required": [
        "orderId",
        "userEmail",
        "totalAmount",
        "createdAt",
        "items"
    ],
    "properties": {
        "orderId": {
            "type": "string",
            "format": "uuid"
        },
        "userEmail": {
            "type": "string",
            "format": "email"
        },
        "totalAmount": {
            "type": "number"
        },
        "createdAt": {
            "type": "string",
            "format": "date-time"
        },
        "items": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "sku",
                    "quantity",
                    "price"
                ],
                "properties": {
                    "sku": {
                        "type": "string"
                    },
                    "quantity": {
                        "type": "integer",
                        "minimum": 1
                    },
                    "price": {
                        "type": "number"
                    }
                }
            }
        }
    }
}